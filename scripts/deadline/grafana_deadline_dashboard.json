      "fieldConfig":{"defaults":{"color":{"fixedColor":"#66BB6A","mode":"fixed"},"decimals":0,
        "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0}]},"unit":"none"},"overrides":[]},
      "options":{"colorMode":"none","graphMode":"none","reduceOptions":{"calcs":["lastNotNull"]},"textMode":"value","wideLayout":true},
      "targets":[{"expr":"deadline_jobs_completed","instant":true,"legendFormat":"Completed","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 14, "type": "stat", "title": "Total", "gridPos": {"x":20,"y":12,"w":4,"h":8},
