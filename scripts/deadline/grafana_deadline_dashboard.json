      "options":{"orientation":"auto","reduceOptions":{"calcs":["lastNotNull"]},"showThresholdLabels":false,"showThresholdMarkers":true},
      "targets":[{"expr":"deadline_farm_utilization_pct","instant":true,"legendFormat":"Utilization","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 8, "type": "text", "title": "", "gridPos": {"x":0,"y":10,"w":24,"h":2},
      "fieldConfig":{"defaults":{},"overrides":[]},
      "options":{"code":{"language":"plaintext","showLineNumbers":false,"showMiniMap":false},
        "content":"<div style='background:#7E57C2;padding:4px 14px;border-radius:5px;font-size:14px;font-weight:700;color:#fff;letter-spacing:1px;display:flex;justify-content:space-between;align-items:center'><span>📋  Jobs</span><span style='font-size:11px;font-weight:500;opacity:0.85'>last 60 days · set JOBS_MAX_AGE_DAYS to change</span></div>","mode":"html"},
      "targets":[], "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 9, "type": "stat", "title": "Rendering", "gridPos": {"x":0,"y":12,"w":4,"h":8},
      "fieldConfig":{"defaults":{
        "color":{"fixedColor":"#42A5F5","mode":"fixed"},
        "noValue":"—","unit":"none"
      },"overrides":[]},
      "options":{
        "colorMode":"background","graphMode":"none","justifyMode":"auto","orientation":"horizontal",
        "reduceOptions":{"calcs":["lastNotNull"],"fields":"","values":true},
        "textMode":"name","wideLayout":true
      },
      "targets":[{"expr":"deadline_job_progress_pct","instant":true,"legendFormat":"{{name}}","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 10, "type": "stat", "title": "Queued", "gridPos": {"x":4,"y":12,"w":4,"h":8},
      "fieldConfig":{"defaults":{"color":{"mode":"thresholds"},"decimals":0,
        "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0},{"color":"yellow","value":1},{"color":"orange","value":10}]},"unit":"none"},"overrides":[]},
      "options":{"colorMode":"background","graphMode":"area","reduceOptions":{"calcs":["lastNotNull"]},"textMode":"value","wideLayout":true},
      "targets":[{"expr":"deadline_jobs_queued","instant":true,"legendFormat":"Queued","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
