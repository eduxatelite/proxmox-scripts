      "targets":[{"expr":"deadline_worker_rendering","instant":true,"legendFormat":"{{name}}","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

