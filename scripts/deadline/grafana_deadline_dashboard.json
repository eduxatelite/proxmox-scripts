        "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0}]},"unit":"none"},"overrides":[]},
      "options":{"colorMode":"none","graphMode":"none","reduceOptions":{"calcs":["lastNotNull"]},"textMode":"value","wideLayout":true},
      "targets":[{"expr":"deadline_jobs_total","instant":true,"legendFormat":"Total","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 15, "type": "text", "title": "", "gridPos": {"x":0,"y":20,"w":24,"h":2},
      "fieldConfig":{"defaults":{},"overrides":[]},
      "options":{"code":{"language":"plaintext","showLineNumbers":false,"showMiniMap":false},
        "content":"<div style='background:#EF6C00;padding:4px 14px;border-radius:5px;font-size:14px;font-weight:700;color:#fff;letter-spacing:1px'>🎬  Currently rendering</div>","mode":"html"},
      "targets":[], "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 16, "type": "table", "title": "Active jobs", "gridPos": {"x":0,"y":22,"w":24,"h":10},
      "fieldConfig": {
        "defaults": {
          "custom": { "align":"left", "cellOptions":{"type":"auto"}, "filterable":false, "inspect":false },
          "thresholds": {"mode":"absolute","steps":[{"color":"green","value":0}]}
        },
        "overrides": [
          { "matcher":{"id":"byName","options":"name"},
            "properties":[{"id":"displayName","value":"Job"},{"id":"custom.width","value":480}] },
          { "matcher":{"id":"byName","options":"department"},
            "properties":[{"id":"displayName","value":"Department"},{"id":"custom.width","value":120}] },
          { "matcher":{"id":"byName","options":"pool"},
            "properties":[{"id":"displayName","value":"Pool"},{"id":"custom.width","value":140}] },
          { "matcher":{"id":"byName","options":"Value #A"},
            "properties":[
              {"id":"displayName","value":"Progress"},
              {"id":"unit","value":"percent"},
              {"id":"decimals","value":1},
              {"id":"custom.cellOptions","value":{"type":"gauge","mode":"gradient","valueDisplayMode":"text"}},
              {"id":"min","value":0},{"id":"max","value":100},
              {"id":"custom.width","value":260}
            ] },
          { "matcher":{"id":"byName","options":"Value #B"},
            "properties":[
              {"id":"displayName","value":"Time remaining"},
              {"id":"unit","value":"s"},
              {"id":"decimals","value":0},
              {"id":"custom.width","value":160}
            ] }
        ]
      },
      "options": { "cellHeight":"sm", "showHeader":true,
        "sortBy":[{"desc":true,"displayName":"Progress"}] },
      "transformations": [
        { "id":"joinByField", "options":{ "byField":"job_id", "mode":"outer" } },
        { "id":"organize", "options":{
            "excludeByName": {
              "Time": true, "Time 1": true, "Time 2": true,
              "__name__": true, "__name__ 1": true, "__name__ 2": true,
              "instance": true, "instance 1": true, "instance 2": true,
              "job": true, "job 1": true, "job 2": true,
              "job_id": true,
              "name 2": true, "pool 2": true, "department 2": true
            },
            "indexByName": {
              "name": 0, "department": 1, "pool": 2, "Value #A": 3, "Value #B": 4
            },
            "renameByName": {}
        }}
      ],
      "targets": [
        { "expr":"deadline_job_progress_pct",      "format":"table","instant":true,"refId":"A",
          "datasource":{"uid":"prometheus","type":"prometheus"} },
        { "expr":"deadline_job_remaining_seconds", "format":"table","instant":true,"refId":"B",
          "datasource":{"uid":"prometheus","type":"prometheus"} }
      ],
      "datasource": {"uid":"prometheus","type":"prometheus"} },

    { "id": 17, "type": "text", "title": "", "gridPos": {"x":0,"y":32,"w":24,"h":2},
      "fieldConfig":{"defaults":{},"overrides":[]},
      "options":{"code":{"language":"plaintext","showLineNumbers":false,"showMiniMap":false},
        "content":"<div style='background:#5E35B1;padding:4px 14px;border-radius:5px;font-size:14px;font-weight:700;color:#fff;letter-spacing:1px;display:flex;justify-content:space-between;align-items:center'><span>🏭  Production view — work remaining by department</span><span style='font-size:11px;font-weight:500;opacity:0.85'>department extracted from job name · set DEPT_REGEX to change</span></div>","mode":"html"},
      "targets":[], "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 18, "type": "bargauge", "title": "Pending Jobs", "gridPos":{"x":0,"y":34,"w":6,"h":10},
      "fieldConfig":{"defaults":{
        "color":{"mode":"continuous-BlPu"}, "decimals":0,
        "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0}]}, "unit":"none"
      },"overrides":[]},
      "options":{"displayMode":"gradient","orientation":"horizontal","showUnfilled":true,
        "minVizWidth":0,"minVizHeight":10,
        "reduceOptions":{"calcs":["lastNotNull"]},"valueMode":"text"},
      "targets":[{"expr":"deadline_dept_pending_jobs","legendFormat":"{{department}}","instant":true,"refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 19, "type": "bargauge", "title": "Pending Tasks", "gridPos":{"x":6,"y":34,"w":6,"h":10},
      "fieldConfig":{"defaults":{
        "color":{"mode":"continuous-BlPu"}, "decimals":0,
