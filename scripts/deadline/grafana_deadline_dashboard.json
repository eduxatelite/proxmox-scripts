      },"overrides":[]},
      "options":{"displayMode":"gradient","orientation":"horizontal","showUnfilled":true,
        "minVizWidth":0,"minVizHeight":10,
        "reduceOptions":{"calcs":["lastNotNull"]},"valueMode":"text"},
      "targets":[{"expr":"deadline_dept_pending_tasks","legendFormat":"{{department}}","instant":true,"refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
