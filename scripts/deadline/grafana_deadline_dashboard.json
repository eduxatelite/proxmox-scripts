      "options":{"colorMode":"background","graphMode":"none","reduceOptions":{"calcs":["lastNotNull"]},"textMode":"value","wideLayout":true},
      "targets":[{"expr":"deadline_jobs_failed","instant":true,"legendFormat":"Failed","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 12, "type": "stat", "title": "Suspended", "gridPos": {"x":12,"y":12,"w":4,"h":8},
