        "color":{"mode":"continuous-BlYlRd"}, "decimals":0,
        "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0}]}, "unit":"s"
      },"overrides":[]},
      "options":{"displayMode":"gradient","orientation":"horizontal","showUnfilled":true,
        "minVizWidth":0,"minVizHeight":10,
        "reduceOptions":{"calcs":["lastNotNull"]},"valueMode":"text"},
      "targets":[{"expr":"deadline_dept_avg_task_seconds","legendFormat":"{{department}}","instant":true,"refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 21, "type": "bargauge", "title": "Estimated Time Left", "gridPos":{"x":18,"y":34,"w":6,"h":10},
      "fieldConfig":{"defaults":{
        "color":{"mode":"continuous-RdYlGr"}, "decimals":0,
        "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0}]}, "unit":"s"
      },"overrides":[]},
      "options":{"displayMode":"gradient","orientation":"horizontal","showUnfilled":true,
        "minVizWidth":0,"minVizHeight":10,
        "reduceOptions":{"calcs":["lastNotNull"]},"valueMode":"text"},
      "targets":[{"expr":"deadline_dept_est_seconds_left","legendFormat":"{{department}}","instant":true,"refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 22, "type": "text", "title": "", "gridPos": {"x":0,"y":44,"w":24,"h":2},
      "fieldConfig":{"defaults":{},"overrides":[]},
      "options":{"code":{"language":"plaintext","showLineNumbers":false,"showMiniMap":false},
        "content":"<div style='background:#455A64;padding:4px 14px;border-radius:5px;font-size:14px;font-weight:700;color:#fff;letter-spacing:1px'>📈  Trends — last 24h</div>","mode":"html"},
      "targets":[], "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 23, "type": "timeseries", "title": "Workers over time", "gridPos":{"x":0,"y":46,"w":12,"h":8},
      "fieldConfig":{"defaults":{
        "custom":{"drawStyle":"line","lineInterpolation":"smooth","lineWidth":2,"fillOpacity":15,"gradientMode":"opacity","showPoints":"never","stacking":{"mode":"none"}},
        "color":{"mode":"palette-classic"},"unit":"none"},
        "overrides":[
          {"matcher":{"id":"byName","options":"Rendering"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"#42A5F5"}}]},
          {"matcher":{"id":"byName","options":"Idle"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"#9CCC65"}}]},
          {"matcher":{"id":"byName","options":"Offline"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"#EF5350"}}]},
          {"matcher":{"id":"byName","options":"Stalled"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"#FFA726"}}]}
        ]},
      "options":{"legend":{"calcs":["lastNotNull","max"],"displayMode":"table","placement":"bottom","showLegend":true},"tooltip":{"mode":"multi","sort":"desc"}},
      "targets":[
        {"expr":"deadline_workers_active","legendFormat":"Rendering","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}},
        {"expr":"deadline_workers_idle","legendFormat":"Idle","refId":"B","datasource":{"uid":"prometheus","type":"prometheus"}},
        {"expr":"deadline_workers_offline","legendFormat":"Offline","refId":"C","datasource":{"uid":"prometheus","type":"prometheus"}},
        {"expr":"deadline_workers_stalled","legendFormat":"Stalled","refId":"D","datasource":{"uid":"prometheus","type":"prometheus"}}
      ],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 24, "type": "timeseries", "title": "Jobs over time", "gridPos":{"x":12,"y":46,"w":12,"h":8},
      "fieldConfig":{"defaults":{
