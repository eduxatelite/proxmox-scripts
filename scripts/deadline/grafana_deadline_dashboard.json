{
  "id": null,
  "uid": "deadline-farm-v1",
  "title": "Deadline — Farm Monitor",
  "description": "Deadline Render Farm — Workers, Jobs, Currently Rendering, Production View & Trends",
  "tags": ["deadline", "render", "farm", "thinkbox"],
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "panels": [

    { "id": 1, "type": "text", "title": "", "gridPos": {"x":0,"y":0,"w":24,"h":2},
