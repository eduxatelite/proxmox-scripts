        "color":{"mode":"palette-classic"},"unit":"none"},
        "overrides":[
          {"matcher":{"id":"byName","options":"Rendering"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"#42A5F5"}}]},
          {"matcher":{"id":"byName","options":"Queued"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"#FFCA28"}}]},
          {"matcher":{"id":"byName","options":"Failed"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"#EF5350"}}]},
          {"matcher":{"id":"byName","options":"Suspended"},"properties":[{"id":"color","value":{"mode":"fixed","fixedColor":"#FFA726"}}]}
        ]},
      "options":{"legend":{"calcs":["lastNotNull","max"],"displayMode":"table","placement":"bottom","showLegend":true},"tooltip":{"mode":"multi","sort":"desc"}},
      "targets":[
        {"expr":"deadline_jobs_rendering","legendFormat":"Rendering","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}},
        {"expr":"deadline_jobs_queued","legendFormat":"Queued","refId":"B","datasource":{"uid":"prometheus","type":"prometheus"}},
        {"expr":"deadline_jobs_failed","legendFormat":"Failed","refId":"C","datasource":{"uid":"prometheus","type":"prometheus"}},
        {"expr":"deadline_jobs_suspended","legendFormat":"Suspended","refId":"D","datasource":{"uid":"prometheus","type":"prometheus"}}
      ],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 25, "type": "timeseries", "title": "Farm utilization %", "gridPos":{"x":0,"y":54,"w":24,"h":6},
      "fieldConfig":{"defaults":{
        "custom":{"drawStyle":"line","lineInterpolation":"smooth","lineWidth":2,"fillOpacity":25,"gradientMode":"opacity","showPoints":"never"},
        "color":{"fixedColor":"#42A5F5","mode":"fixed"},"max":100,"min":0,"unit":"percent"},"overrides":[]},
      "options":{"legend":{"calcs":["mean","max"],"displayMode":"table","placement":"bottom","showLegend":true},"tooltip":{"mode":"single","sort":"none"}},
      "targets":[{"expr":"deadline_farm_utilization_pct","legendFormat":"Utilization","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 26, "type": "stat", "title": "Exporter health", "gridPos":{"x":0,"y":60,"w":6,"h":3},
      "fieldConfig":{"defaults":{
        "color":{"mode":"thresholds"},"decimals":0,
        "mappings":[{"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}],
        "thresholds":{"mode":"absolute","steps":[{"color":"red","value":0},{"color":"green","value":1}]},"unit":"none"},"overrides":[]},
      "options":{"colorMode":"background","graphMode":"none","reduceOptions":{"calcs":["lastNotNull"]},"textMode":"auto","wideLayout":true},
      "targets":[{"expr":"deadline_up","instant":true,"legendFormat":"up","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 27, "type": "stat", "title": "Scrape duration", "gridPos":{"x":6,"y":60,"w":6,"h":3},
      "fieldConfig":{"defaults":{"color":{"mode":"thresholds"},"decimals":2,
        "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0},{"color":"yellow","value":1},{"color":"red","value":5}]},"unit":"s"},"overrides":[]},
      "options":{"colorMode":"value","graphMode":"area","reduceOptions":{"calcs":["lastNotNull"]},"textMode":"auto","wideLayout":true},
      "targets":[{"expr":"deadline_scrape_duration_seconds","instant":true,"legendFormat":"Scrape","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 28, "type": "stat", "title": "Scrape errors (1h)", "gridPos":{"x":12,"y":60,"w":6,"h":3},
      "fieldConfig":{"defaults":{"color":{"mode":"thresholds"},"decimals":0,
        "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0},{"color":"red","value":1}]},"unit":"none"},"overrides":[]},
      "options":{"colorMode":"value","graphMode":"none","reduceOptions":{"calcs":["lastNotNull"]},"textMode":"auto","wideLayout":true},
      "targets":[{"expr":"increase(deadline_scrape_errors_total[1h])","instant":true,"legendFormat":"Errors","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} }

  ]
}
