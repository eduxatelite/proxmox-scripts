    { "id": 6, "type": "stat", "title": "Total", "gridPos": {"x":16,"y":2,"w":4,"h":8},
      "fieldConfig":{"defaults":{"color":{"fixedColor":"#1E88E5","mode":"fixed"},"decimals":0,
        "thresholds":{"mode":"absolute","steps":[{"color":"green","value":0}]},"unit":"none"},"overrides":[]},
      "options":{"colorMode":"none","graphMode":"none","reduceOptions":{"calcs":["lastNotNull"]},"textMode":"value","wideLayout":true},
      "targets":[{"expr":"deadline_workers_total","instant":true,"legendFormat":"Total","refId":"A","datasource":{"uid":"prometheus","type":"prometheus"}}],
      "datasource":{"uid":"prometheus","type":"prometheus"} },

    { "id": 7, "type": "gauge", "title": "Farm utilization", "gridPos": {"x":20,"y":2,"w":4,"h":8},
