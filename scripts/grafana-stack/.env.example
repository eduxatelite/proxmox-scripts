# Grafana Stack — Environment Variables
# Copy this file to .env and fill in your values, OR run install.sh to generate it automatically.

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_ROOT_URL=http://YOUR_SERVER_IP:3000

# ─── Prometheus ──────────────────────────────────────────────────────────────
# How long to keep metrics data
PROMETHEUS_RETENTION=30d
